OKX_API_KEY=your_api_key
OKX_API_SECRET=your_api_secret
OKX_API_PASSPHRASE=your_passphrase

# 1 = OKX demo trading header enabled. Keep this as 1 for simulated trading.
OKX_DEMO=1

# Keep this at 0 unless you intentionally want the dashboard to send orders.
OKX_ENABLE_LIVE_TRADING=0

# Extra fuse. Keep 0 unless you intentionally want to allow orders with OKX_DEMO=0.
OKX_ALLOW_REAL_ENV_TRADING=0

# Usually leave this unchanged.
OKX_BASE_URL=https://www.okx.com

# Google Drive / Colab sync settings.
GDRIVE_KLINE_FOLDER_NAME=klinetraning
GDRIVE_SYNC_INTERVAL_SEC=1800
GDRIVE_EXTRA_TAGS=
